# App
APP_ENV=development
APP_URL=http://localhost:3001
PORT=3001
FRONTEND_ORIGINS=http://localhost:3000

# Database (Supabase)
DATABASE_URL=postgresql://...pooler...:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://...:5432/postgres

# Kinde Auth
KINDE_ISSUER_URL=https://YOUR_SUBDOMAIN.kinde.com
KINDE_AUDIENCE=https://bagi-rata-api.vercel.app/

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.0-flash

# Midtrans
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# Cron
CRON_SECRET=change-me

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# Tanpa ini push disabled; app tetap jalan
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@bagirata.id

# Settlement pending auto-expire (hari)
SETTLEMENT_EXPIRE_DAYS=14

LOG_LEVEL=log
